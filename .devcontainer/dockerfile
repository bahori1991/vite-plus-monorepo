FROM debian:bookworm-slim@sha256:4724b8cc51e33e398f0e2e15e18d5ec2851ff0c2280647e1310bc1642182655d

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Tokyo

# セキュリティ更新を含むシステムパッケージの更新
RUN apt update && \
    apt upgrade -y && \
    apt install -y --no-install-recommends \
        procps \
        git \
        tzdata \
        bash-completion \
        openssh-client \
        curl \
        lsof \
        xz-utils \
        ca-certificates \
        dumb-init \
        gosu && \
    apt autoremove -y && \
    apt clean && \
    rm -rf /var/lib/apt/lists/*

# non-root ユーザーを作成
RUN groupadd -g 1001 appuser && \
    useradd -u 1001 -g appuser -s /bin/bash -m appuser

# 作業ディレクトリを作成して権限を付与
RUN mkdir -p /home/appuser/workspace && \
    chown -R appuser:appuser /home/appuser/workspace

# 日本時間に設定
RUN ln -snf /usr/share/zoneinfo/${TZ} /etc/localtime && \
    echo "${TZ}" > /etc/timezone

# vite.plusをPATHに追加
ENV VP_HOME="/home/appuser/.vite-plus"
ENV PATH="${VP_HOME}/bin:${PATH}"

# 信頼できるvite.plusのハッシュ値をコピー
COPY /scripts/vite-plus-install.sha256 /tmp/expected.sha256

# vite.plusのハッシュ値を検証して一致していればvite.plusをインストール
RUN curl -fsSL --proto "=https" --tlsv1.2 https://vite.plus -o /tmp/vite-plus-install.sh && \
    actual="$(sha256sum /tmp/vite-plus-install.sh | awk '{print $1}')" && \
    expected="$(awk '{print $1}' /tmp/expected.sha256)" && \
    test "$actual" = "$expected" || \
        (echo "SHA256 mismatch: expected $expected got $actual" >&2; exit 1) && \
    bash /tmp/vite-plus-install.sh && \
    rm -f /tmp/vite-plus-install.sh /tmp/expected.sha256

# entrypointのコピー
COPY scripts/entrypoint.sh /home/appuser/entrypoint.sh
RUN chmod +x /home/appuser/entrypoint.sh

# 以降は appuser で動作させる
USER appuser

# .bashrcのコピー
COPY --chown=appuser:appuser scripts/.bashrc /home/appuser/.bashrc

# login shell / sh -l でも vite-plus の PATH 等を有効にする
RUN grep -qF '. "$HOME/.vite-plus/env"' /home/appuser/.profile 2>/dev/null || \
    echo '. "$HOME/.vite-plus/env"' >> /home/appuser/.profile

# 作業ディレクトリの設定
WORKDIR /home/appuser/workspace

# より安全なデフォルトコマンド
USER root
ENTRYPOINT [ "/home/appuser/entrypoint.sh" ]
CMD ["sleep", "infinity"]
