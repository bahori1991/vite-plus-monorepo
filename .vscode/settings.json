{
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.tanstack": true,
    "**/.vite-hooks/_": true,
    "**/Thumbs.db": true,
    "**/node_modules": true
  },
  "files.readonlyInclude": {
    "**/.tanstack/**": true,
    "**/.vite-hooks/_/**": true,
    "**/dist/**": true,
    "**/drizzle/**": true,
    "**/node_modules/**": true,
    "**/pnpm-lock.yaml": true,
    "**/routeTree.gen.ts": true,
    "**/skills-lock.json": true
  },
  "files.watcherExclude": {
    "**/.cache/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/.tanstack/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/drizzle/**": true,
    "**/node_modules/*/**": true,
    "**/tmp/**": true
  },
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "material-icon-theme.files.associations": {
    ".env.keys": "Key",
    "cspell.json": "I18n",
    "tsconfig/base.json": "Tsconfig"
  },
  "material-icon-theme.folders.associations": {
    ".vite-hooks": "Powershell",
    "query": "Rules",
    "shadcn": "Download",
    "tanstack-devtools": "Seeders",
    "tsconfig": "Typescript"
  },
  "oxc.fmt.configPath": "./vite.config.ts",
  "oxc.path.oxfmt": "/home/appuser/.vite-plus/current/node_modules/.bin/oxfmt",
  "oxc.path.oxlint": "/home/appuser/.vite-plus/current/node_modules/.bin/oxlint",
  "search.exclude": {
    "**/*.code-search": true,
    "**/.tanstack": true,
    "**/build": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true
  },
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.tsdk": "node_modules/typescript/lib"
}
