{
  "extends": "@tools/tsconfig/base.json",
  "compilerOptions": {
    "verbatimModuleSyntax": false,
    "paths": {
      "@apps/web/*": ["./src/*"],
      "@packages/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "./src/**/*",
    "./vite.config.ts",
    "../../packages/ui/src/components/theme/theme-provider.tsx",
    "../../packages/ui/src/components/theme/theme-toggle.tsx"
  ],
  "exclude": ["node_modules", "dist", ".tanstack"]
}
