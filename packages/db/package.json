{
  "name": "@packages/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.mts",
      "default": "./dist/schemas/*.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint",
    "generate": "vpx drizzle-kit generate",
    "migrate": "vpx drizzle-kit migrate",
    "push": "vpx drizzle-kit push",
    "studio": "vpx drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@tools/env": "workspace:*",
    "@tools/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "drizzle-kit": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-start": "catalog:"
  },
  "inlinedDependencies": {
    "@t3-oss/env-core": "0.13.11",
    "zod": "4.3.6"
  }
}
