{
  "name": "@tools/env",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "dev": "concurrently \"pnpm:dev:*\"",
    "dev:web": "dotenvx run -f .env.development -- vp run --filter=@apps/web dev",
    "dev:api": "dotenvx run -f .env.development -- vp run --filter=@apps/api dev",
    "db:push": "dotenvx run -f .env.development -- vp run --filter=@packages/db push",
    "db:studio": "dotenvx run -f .env.development -- vp run --filter=@packages/db studio",
    "get": "dotenvx get",
    "set": "dotenvx set",
    "encrypt": "dotenvx encrypt"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "catalog:",
    "@tools/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "concurrently": "catalog:",
    "vite": "catalog:"
  }
}
